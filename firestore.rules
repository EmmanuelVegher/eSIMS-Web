rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper: checks if user is logged in
    function isAuthenticated() {
      return request.auth != null;
    }
    
    // Helper: checks if user is accessing their own document
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    // Helper: checks if user has 'Admin' role in users collection
    function isAdmin() {
      return isAuthenticated() && 
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'Admin';
    }

    // 1. Roles: public read (for registration dropdown), write only by Admin
    match /roles/{roleId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    // Organizations: public read (for registration dropdown), write only by Admin
    match /organizations/{orgId} {
      allow read: if true;
      allow write: if isAdmin();
      
      // Allow cascading subcollections under Facilities (state / facilities)
      match /Facilities/{document=**} {
        allow read: if true;
        allow write: if isAdmin();
      }
    }

    // 2. Users: strict owner-only read/write
    match /users/{userId} {
      allow read, write: if isOwner(userId) || isAdmin();
    }

    // 3. CEEs and Questions: read-only for users, write only by Admin
    match /cees/{ceeId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }
    
    match /questions/{questionId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // 4. Question Responses: authenticated read/write for assessment logs
    match /question_response/{responseId} {
      allow read, write: if isAuthenticated();
    }

    // 5. SIMS Activities: read-only for authenticated assessors, write only by Admin
    match /sims_activities/{activityId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }
  }
}
